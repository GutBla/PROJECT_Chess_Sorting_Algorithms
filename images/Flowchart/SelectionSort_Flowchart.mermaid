flowchart TD
    Start([Inicio: Selection Sort]) --> Init[i = 0]
    Init --> Outer{"i < n-1?"}
    Outer -->|No| End([Fin: Ordenado])
    Outer -->|Sí| SetMin[min_idx = i]
    
    SetMin --> InnerInit[j = i + 1]
    InnerInit --> Inner{"j < n?"}
    Inner -->|No| Check{"min_idx != i?"}
    Inner -->|Sí| Comp{"arr[j] < arr[min_idx]?"}
    
    Comp -->|Sí| Update[min_idx = j]
    Comp -->|No| NextJ[j++]
    Update --> NextJ
    NextJ --> Inner
    
    Check -->|Sí| Swap["Intercambiar arr[i] con arr[min_idx]"]
    Check -->|No| NextI[i++]
    Swap --> NextI
    NextI --> Outer